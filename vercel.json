{
  "version": 2,
  "rewrites": [
    {
      "source": "/research/:transport*",
      "destination": "/api/research"
    },
    {
      "source": "/content/:transport*",
      "destination": "/api/content"
    },
    {
      "source": "/auditor/:transport*",
      "destination": "/api/auditor"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/packages/dashboard/src/pages/index.tsx"
    }
  ]
}
